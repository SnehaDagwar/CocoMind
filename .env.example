# Azure Document Intelligence
AZURE_DOCINT_KEY=your-azure-key-here
AZURE_DOCINT_ENDPOINT=https://your-region.api.cognitive.microsoft.com/

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-key-here

# PostgreSQL
DATABASE_URL=postgresql://cocomind:cocomind@localhost:5432/cocomind

# ChromaDB
CHROMADB_PATH=./data/chromadb

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Whoosh index
WHOOSH_INDEX_PATH=./data/whoosh_index

# Audit
AUDIT_DB_PATH=./data/audit/audit.db

# DSC / Signing
DSC_PKCS11_LIB=/path/to/pkcs11/library.so

# App
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
